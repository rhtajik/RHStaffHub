@page "{id:guid}"
@model RHStaffHub.Web.Pages.Departments.DetailsModel
@{
    ViewData["Title"] = "Afdelingsdetaljer";
}

<div class="container">
    <h1 class="mb-4">@Model.Department.Name</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Oplysninger</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Navn</dt>
                        <dd class="col-sm-9">@Model.Department.Name</dd>

                        <dt class="col-sm-3">Beskrivelse</dt>
                        <dd class="col-sm-9">@(Model.Department.Description ?? "-")</dd>

                        <dt class="col-sm-3">Adresse</dt>
                        <dd class="col-sm-9">@(Model.Department.Address ?? "-")</dd>

                        <dt class="col-sm-3">Lokations ID</dt>
                        <dd class="col-sm-9">@(Model.Department.LocationId ?? "-")</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.Department.IsActive)
                            {
                                <span class="badge bg-success">Aktiv</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inaktiv</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">GPS Clock-in</h5>
                </div>
                <div class="card-body">
                    @if (Model.Department.GpsLatitude.HasValue && Model.Department.GpsLongitude.HasValue)
                    {
                        <dl class="row">
                            <dt class="col-sm-3">Latitude</dt>
                            <dd class="col-sm-9">@Model.Department.GpsLatitude</dd>

                            <dt class="col-sm-3">Longitude</dt>
                            <dd class="col-sm-9">@Model.Department.GpsLongitude</dd>

                            <dt class="col-sm-3">Radius</dt>
                            <dd class="col-sm-9">@Model.Department.GpsRadiusMeters meter</dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">GPS er ikke aktiveret for denne afdeling.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Handlinger</h5>
                </div>
                <div class="card-body">
                    <a asp-page="./Edit" asp-route-id="@Model.Department.Id" class="btn btn-primary w-100 mb-2">Rediger</a>
                    <a asp-page="./Index" class="btn btn-outline-secondary w-100">Tilbage til liste</a>
                </div>
            </div>
        </div>
    </div>
</div>