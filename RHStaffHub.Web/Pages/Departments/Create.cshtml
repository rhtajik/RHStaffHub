@page
@model RHStaffHub.Web.Pages.Departments.CreateModel
@{
    ViewData["Title"] = "Ny Afdeling";
}

<div class="container">
    <h1 class="mb-4">Opret Ny Afdeling</h1>

    <div class="row">
        <div class="col-md-6">
            <form method="post" asp-page="./Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Department.Name" class="form-label">Navn *</label>
                    <input asp-for="Department.Name" class="form-control" placeholder="f.eks. Køkken, Butik Aalborg" />
                    <span asp-validation-for="Department.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.Description" class="form-label">Beskrivelse</label>
                    <textarea asp-for="Department.Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.Address" class="form-label">Adresse</label>
                    <input asp-for="Department.Address" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Department.LocationId" class="form-label">Lokations ID</label>
                    <input asp-for="Department.LocationId" class="form-control" placeholder="f.eks. AAL-001" />
                </div>

                <hr />
                <h5>GPS Clock-in (valgfrit)</h5>
                <p class="text-muted small">Medarbejdere kan kun checke ind inden for denne radius</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Department.GpsLatitude" class="form-label">Latitude</label>
                        <input asp-for="Department.GpsLatitude" class="form-control" placeholder="57.0488" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Department.GpsLongitude" class="form-label">Longitude</label>
                        <input asp-for="Department.GpsLongitude" class="form-control" placeholder="9.9217" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.GpsRadiusMeters" class="form-label">Radius (meter)</label>
                    <input asp-for="Department.GpsRadiusMeters" class="form-control" value="100" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Gem Afdeling</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}