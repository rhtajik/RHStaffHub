@page
@model RHStaffHub.Web.Pages.Departments.CreateModel
@{
    ViewData["Title"] = "Ny Afdeling";
}

<div class="container">
    <h1 class="mb-4">Opret Ny Afdeling</h1>

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                @Html.AntiForgeryToken()

                <div class="text-danger" asp-validation-summary="All"></div>

                <div class="mb-3">
                    <label class="form-label">Navn *</label>
                    <input asp-for="Department.Name" class="form-control" />
                    <span asp-validation-for="Department.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Beskrivelse</label>
                    <textarea asp-for="Department.Description" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Adresse</label>
                    <input asp-for="Department.Address" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Lokations ID</label>
                    <input asp-for="Department.LocationId" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Latitude</label>
                        <input asp-for="Department.GpsLatitude" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Longitude</label>
                        <input asp-for="Department.GpsLongitude" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Radius (meter)</label>
                    <input asp-for="Department.GpsRadiusMeters" class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Gem Afdeling</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>