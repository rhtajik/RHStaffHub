@page "{id:guid}"
@model RHStaffHub.Web.Pages.Departments.EditModel
@{
    ViewData["Title"] = "Rediger Afdeling";
}

<div class="container">
    <h1 class="mb-4">Rediger Afdeling</h1>

    <div class="row">
        <!-- Venstre kolonne: Form -->
        <div class="col-md-5">
            <form method="post" id="departmentForm">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Department.Id" />
                <input type="hidden" asp-for="Department.TenantId" />
                <input type="hidden" asp-for="Department.CompanyId" />

                <div class="mb-3">
                    <label asp-for="Department.Name" class="form-label">Navn *</label>
                    <input asp-for="Department.Name" class="form-control" required />
                    <span asp-validation-for="Department.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.Description" class="form-label">Beskrivelse</label>
                    <textarea asp-for="Department.Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.Address" class="form-label">Adresse</label>
                    <input asp-for="Department.Address" class="form-control" id="addressInput" />
                    <button type="button" class="btn btn-sm btn-outline-primary mt-1" onclick="searchAddress()">
                        <i class="bi bi-search"></i> Søg på kort
                    </button>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.LocationId" class="form-label">Lokations ID</label>
                    <input asp-for="Department.LocationId" class="form-control" />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Department.IsActive" class="form-check-input" />
                    <label asp-for="Department.IsActive" class="form-check-label">Aktiv</label>
                </div>

                <hr />
                <h6><i class="bi bi-geo-alt-fill text-danger"></i> GPS Clock-in Zone</h6>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label asp-for="Department.GpsLatitude" class="form-label">Latitude</label>
                        <input asp-for="Department.GpsLatitude"
                               class="form-control"
                               id="latInput"
                               type="text"
                               value="@(Model.Department.GpsLatitude?.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
                    </div>
                    <div class="col-6 mb-3">
                        <label asp-for="Department.GpsLongitude" class="form-label">Longitude</label>
                        <input asp-for="Department.GpsLongitude"
                               class="form-control"
                               id="lngInput"
                               type="text"
                               value="@(Model.Department.GpsLongitude?.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Department.GpsRadiusMeters" class="form-label">Radius (meter)</label>
                    <input asp-for="Department.GpsRadiusMeters" class="form-control" id="radiusInput" min="10" max="1000" />
                    <small class="text-muted">Medarbejdere skal være inden for denne radius for at checke ind</small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Gem Ændringer</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                    <button type="submit" asp-page-handler="Delete" class="btn btn-danger ms-auto" onclick="return confirm('Er du sikker på du vil slette denne afdeling?');">Slet</button>
                </div>
            </form>
        </div>

        <!-- Højre kolonne: Kort -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-map"></i> GPS Position</h6>
                    @if (Model.Department.GpsLatitude.HasValue && Model.Department.GpsLongitude.HasValue)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> GPS Aktiv</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle"></i> Ingen GPS</span>
                    }
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 500px; width: 100%;"></div>
                </div>
                <div class="card-footer text-muted small">
                    <i class="bi bi-info-circle"></i> Klik på kortet for at ændre GPS position. Træk i markøren for at justere.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Leaflet CSS & JS (OpenStreetMap - Gratis) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        let map;
        let marker;
        let circle;

        // Brug eksisterende værdier fra modellen
        const existingLat = @(Model.Department.GpsLatitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
        const existingLng = @(Model.Department.GpsLongitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");

        // Default til København hvis ingen eksisterende værdier
        const defaultLat = existingLat || 55.6761;
        const defaultLng = existingLng || 12.5683;

        function initMap() {
            // Hent værdier fra form eller brug default
            let latInput = document.getElementById('latInput').value.replace(',', '.');
            let lngInput = document.getElementById('lngInput').value.replace(',', '.');
            let lat = parseFloat(latInput) || defaultLat;
            let lng = parseFloat(lngInput) || defaultLng;

            // Opret kort
            map = L.map('map').setView([lat, lng], existingLat ? 15 : 13);

            // Tilføj OpenStreetMap tiles (gratis)
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            // Tilføj marker og cirkel
            updateMarker(lat, lng);

            // Klik på kort for at sætte position
            map.on('click', function(e) {
                updateMarker(e.latlng.lat, e.latlng.lng);
                updateForm(e.latlng.lat, e.latlng.lng);
            });
        }

        function updateMarker(lat, lng) {
            // Fjern eksisterende
            if (marker) map.removeLayer(marker);
            if (circle) map.removeLayer(circle);

            // Tilføj ny marker
            marker = L.marker([lat, lng], { draggable: true }).addTo(map);

            // Tilføj cirkel (radius)
            let radius = parseInt(document.getElementById('radiusInput').value) || 100;
            circle = L.circle([lat, lng], {
                color: 'red',
                fillColor: '#f03',
                fillOpacity: 0.2,
                radius: radius
            }).addTo(map);

            // Marker kan trækkes
            marker.on('dragend', function(e) {
                let pos = e.target.getLatLng();
                updateForm(pos.lat, pos.lng);
                updateCircle(pos.lat, pos.lng);
            });
        }

        function updateCircle(lat, lng) {
            if (circle) map.removeLayer(circle);
            let radius = parseInt(document.getElementById('radiusInput').value) || 100;
            circle = L.circle([lat, lng], {
                color: 'red',
                fillColor: '#f03',
                fillOpacity: 0.2,
                radius: radius
            }).addTo(map);
        }

        function updateForm(lat, lng) {
            // Brug punktum som decimal separator
            document.getElementById('latInput').value = lat.toFixed(6);
            document.getElementById('lngInput').value = lng.toFixed(6);
        }

        // Opdater cirkel når radius ændres
        document.getElementById('radiusInput').addEventListener('change', function() {
            let latInput = document.getElementById('latInput').value.replace(',', '.');
            let lngInput = document.getElementById('lngInput').value.replace(',', '.');
            let lat = parseFloat(latInput);
            let lng = parseFloat(lngInput);
            if (lat && lng) {
                updateCircle(lat, lng);
            }
        });

        // Opdater cirkel når koordinater ændres manuelt
        document.getElementById('latInput').addEventListener('change', updateFromForm);
        document.getElementById('lngInput').addEventListener('change', updateFromForm);

        function updateFromForm() {
            let latInput = document.getElementById('latInput').value.replace(',', '.');
            let lngInput = document.getElementById('lngInput').value.replace(',', '.');
            let lat = parseFloat(latInput);
            let lng = parseFloat(lngInput);
            if (lat && lng) {
                updateMarker(lat, lng);
                map.setView([lat, lng], 15);
            }
        }

        // Søg adresse
        function searchAddress() {
            let address = document.getElementById('addressInput').value;
            if (!address) {
                alert('Indtast en adresse først');
                return;
            }

            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}&limit=1`)
                .then(response => response.json())
                .then(data => {
                    if (data && data.length > 0) {
                        let lat = parseFloat(data[0].lat);
                        let lng = parseFloat(data[0].lon);
                        updateMarker(lat, lng);
                        updateForm(lat, lng);
                        map.setView([lat, lng], 16);
                    } else {
                        alert('Adresse ikke fundet. Prøv at vælge manuelt på kortet.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Kunne ikke søge efter adresse. Vælg manuelt på kortet.');
                });
        }

        // Initialiser kort når siden loader
        document.addEventListener('DOMContentLoaded', initMap);
    </script>
}