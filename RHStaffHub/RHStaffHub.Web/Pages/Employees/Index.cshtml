@page
@model RHStaffHub.Web.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Medarbejdere";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Medarbejdere</h1>
        <div class="d-flex gap-2">
            @if (Model.ShowInactive)
            {
                <a asp-page="./Index" class="btn btn-outline-primary">
                    <i class="bi bi-eye"></i> Vis Aktive
                </a>
            }
            else
            {
                <a asp-page="./Index" asp-route-showInactive="true" class="btn btn-outline-secondary">
                    <i class="bi bi-eye-slash"></i> Vis Inaktive
                </a>
            }
            <a asp-page="./Create" class="btn btn-success">
                <i class="bi bi-person-plus"></i> Ny Medarbejder
            </a>
        </div>
    </div>

    @if (Model.ShowInactive)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Viser inaktive (slettede) medarbejdere
        </div>
    }

    @if (Model.Employees.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Navn</th>
                        <th>Email</th>
                        <th>Rolle</th>
                        <th>Afdeling</th>
                        <th>Timeløn</th>
                        <th>Status</th>
                        <th>Handlinger</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in Model.Employees)
                    {
                        <tr class="@(!employee.IsActive ? "table-secondary" : "")">
                            <td>@employee.FullName</td>
                            <td>@employee.Email</td>
                            <td>
                                <span class="badge bg-@(employee.Role == "Admin" ? "danger" : employee.Role == "Manager" ? "warning" : "info")">
                                    @employee.Role
                                </span>
                            </td>
                            <td>@(employee.PrimaryDepartment?.Name ?? "-")</td>
                            <td>@employee.HourlyRate.ToString("C")</td>
                            <td>
                                @if (employee.IsActive)
                                {
                                    <span class="badge bg-success">Aktiv</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inaktiv</span>
                                }
                            </td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-primary">Rediger</a>
                                <a asp-page="./Details" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-secondary">Detaljer</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            @if (Model.ShowInactive)
            {
                <span>Ingen inaktive medarbejdere.</span>
            }
            else
            {
                <span>Ingen aktive medarbejdere. <a asp-page="./Create">Opret den første medarbejder</a>.</span>
            }
        </div>
    }
</div>