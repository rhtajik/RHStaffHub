@page
@model RHStaffHub.Web.Pages.Employees.CreateModel
@{
    ViewData["Title"] = "Ny Medarbejder";
}

<div class="container">
    <h1 class="mb-4">Opret Ny Medarbejder</h1>

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger"></div>

                <h5>Personlige Oplysninger</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.FirstName" class="form-label">Fornavn *</label>
                        <input asp-for="Input.FirstName" class="form-control" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.LastName" class="form-label">Efternavn *</label>
                        <input asp-for="Input.LastName" class="form-control" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email *</label>
                    <input asp-for="Input.Email" type="email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.PhoneNumber" class="form-label">Telefon</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.EmployeeNumber" class="form-label">Medarbejder Nummer</label>
                    <input asp-for="Input.EmployeeNumber" class="form-control" placeholder="f.eks. EMP-001" />
                </div>

                <hr />
                <h5>Ansættelse</h5>

                <div class="mb-3">
                    <label asp-for="Input.Role" class="form-label">Rolle *</label>
                    <select asp-for="Input.Role" class="form-select" asp-items="Model.Roles">
                        <option value="">Vælg rolle...</option>
                    </select>
                    <span asp-validation-for="Input.Role" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.PrimaryDepartmentId" class="form-label">Primær Afdeling</label>
                    <select asp-for="Input.PrimaryDepartmentId" class="form-select" asp-items="Model.Departments">
                        <option value="">Vælg afdeling...</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.HourlyRate" class="form-label">Timeløn (DKK)</label>
                    <input asp-for="Input.HourlyRate" type="number" step="0.01" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Adgangskode *</label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Gem Medarbejder</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}