@page "{id:guid}"
@model RHStaffHub.Web.Pages.Shifts.EditModel
@{
    ViewData["Title"] = "Rediger Vagt";
}

<div class="container">
    <h1 class="mb-4">Rediger Vagt</h1>

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Shift.Id" />
                <input type="hidden" asp-for="Shift.TenantId" />

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Shift.DepartmentId" class="form-label">Afdeling</label>
                    <select asp-for="Shift.DepartmentId" class="form-select" asp-items="Model.Departments">
                        <option value="">Vælg afdeling...</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.EmployeeId" class="form-label">Medarbejder</label>
                    <select asp-for="Shift.EmployeeId" class="form-select" asp-items="Model.Employees">
                        <option value="">Åben vagt</option>
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Dato</label>
                        <input type="date" class="form-control" value="@Model.Shift.StartTime.ToString("yyyy-MM-dd")" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartTime" class="form-label">Start Tid</label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EndTime" class="form-label">Slut Tid</label>
                        <input asp-for="EndTime" type="time" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.Title" class="form-label">Titel/Beskrivelse</label>
                    <input asp-for="Shift.Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.Notes" class="form-label">Noter</label>
                    <textarea asp-for="Shift.Notes" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.Status" class="form-label">Status</label>
                    <select asp-for="Shift.Status" class="form-select">
                        <option value="Scheduled">Planlagt</option>
                        <option value="Confirmed">Bekræftet</option>
                        <option value="Completed">Afsluttet</option>
                        <option value="Cancelled">Annulleret</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Gem Ændringer</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                    <button type="submit" asp-page-handler="Delete" class="btn btn-danger ms-auto"
                            onclick="return confirm('Er du sikker på du vil slette denne vagt?');">
                        Slet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}