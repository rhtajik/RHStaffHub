@page "{id:guid}"
@model RHStaffHub.Web.Pages.Shifts.AssignModel
@{
    ViewData["Title"] = "Tildel Vagt";
}

<div class="container">
    <h1 class="mb-4">Tildel Vagt</h1>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Vagt Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Afdeling:</strong> @Model.Shift.Department?.Name</p>
                    <p><strong>Dato:</strong> @Model.Shift.StartTime.ToString("dddd dd/MM yyyy")</p>
                    <p><strong>Tid:</strong> @Model.Shift.StartTime.ToString("HH:mm") - @Model.Shift.EndTime.ToString("HH:mm")</p>
                    <p><strong>Varighed:</strong> @Model.Shift.Duration.TotalHours timer</p>
                    @if (!string.IsNullOrEmpty(Model.Shift.Title))
                    {
                        <p><strong>Titel:</strong> @Model.Shift.Title</p>
                    }
                </div>
            </div>

            <form method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="SelectedEmployeeId" class="form-label">Vælg Medarbejder *</label>
                    <select asp-for="SelectedEmployeeId" class="form-select" asp-items="Model.AvailableEmployees" required>
                        <option value="">Vælg medarbejder...</option>
                    </select>
                    <span asp-validation-for="SelectedEmployeeId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Besked til medarbejder (valgfrit)</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="f.eks. Husk at tage hvide sko med..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Tildel Vagt</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}