@page
@model RHStaffHub.Web.Pages.Shifts.CreateModel
@{
    ViewData["Title"] = "Ny Vagt";
}

<div class="container">
    <h1 class="mb-4">Opret Ny Vagt</h1>

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Shift.DepartmentId" class="form-label">Afdeling *</label>
                    <select asp-for="Shift.DepartmentId" class="form-select" asp-items="Model.Departments" required>
                        <option value="">Vælg afdeling...</option>
                    </select>
                    <span asp-validation-for="Shift.DepartmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.EmployeeId" class="form-label">Medarbejder</label>
                    <select asp-for="Shift.EmployeeId" class="form-select" asp-items="Model.Employees">
                        <option value="">Åben vagt (ingen tildelt)</option>
                    </select>
                    <small class="text-muted">Lad være tom for åben vagt</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartDate" class="form-label">Dato *</label>
                        <input asp-for="StartDate" type="date" class="form-control" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartTime" class="form-label">Start Tid *</label>
                        <input asp-for="StartTime" type="time" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EndTime" class="form-label">Slut Tid *</label>
                        <input asp-for="EndTime" type="time" class="form-control" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.Title" class="form-label">Titel/Beskrivelse</label>
                    <input asp-for="Shift.Title" class="form-control" placeholder="f.eks. Aftenhold, Weekend" />
                </div>

                <div class="mb-3">
                    <label asp-for="Shift.Notes" class="form-label">Noter</label>
                    <textarea asp-for="Shift.Notes" class="form-control" rows="2"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Gem Vagt</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}